# Voting Signal Agent — Environment Variables

# Discord webhook — CREATE A NEW CHANNEL for this, separate from master agent
DISCORD_VOTING_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# TwelveData API keys (same ones as master agent, or separate)
TWELVEDATA_API_KEY_1=your_key_here
TWELVEDATA_API_KEY_2=your_key_here
TWELVEDATA_API_KEY_3=your_key_here
TWELVEDATA_API_KEY_4=your_key_here
TWELVEDATA_API_KEY_5=your_key_here

# Set to true to see no-consensus signals in Discord (for debugging)
DEBUG_MODE=false
